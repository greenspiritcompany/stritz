<!DOCTYPE ParticleEffect SYSTEM '../../dtd/particle_effect.dtd'>
<ParticleEffect maxParticles="8" space="Local" timeToEmit="2" name="castle_bubble_pfx">
    <Dampening min="0.900" max="0.980"/>
    <DirectionalForce x="0" y="600"/>
    <Emitter emissionRate="0.100" spread="45" angle="90">
        <SpawnArea width="30" depth="0" height="10"/>
    </Emitter>
    <EndColor b="255" r="255" g="255" a="50"/>
    <Rotation min="20" max="90"/>
    <RotationSpeed min="90" max="90"/>
    <Size>
        <Max x="30" y="30"/>
        <Min x="20" y="20"/>
    </Size>
    <SizeChange>
        <Max x="-25" y="-25"/>
        <Min x="0" y="0"/>
    </SizeChange>
    <StartColor b="255" r="255" g="255" a="200"/>
    <Texture numFramesY="1" blend="Multiply" numFramesX="1" filename="shared/bootstrap/particles/tex/bubble.png"/>
    <TextureFrame numTextureAnimationFrames="1" textureAnimationSpeed="60" startFrame="0"/>
    <TimeToLive min="0.700" max="1.500"/>
    <Velocity min="180" max="280"/>
</ParticleEffect>

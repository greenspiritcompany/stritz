				</Panel>
			</SceneObject>
			<SceneObject>
				<Translation x="-230" y="-3" />
				<Sprite filename="shared/diorama/common/tex/gui_elements/cross.png" vertexColors="false">
					<Pivot anchor="center" />
				</Sprite>
			</SceneObject>
			<SceneObject name="Message">
				<Translation x="0" y="0" />
				<Text canBreakWords="false" font="Typewriter" alignment="center" verticalAlignment="visualCenter" maxWidth="390" maxHeight="80" overflowBehaviour="fit" key="no_internet_access">
					<Color r="223" g="31" b="31" />
					<Size x="22" y="22" />
				</Text>
			</SceneObject>
		</SceneObject>
		<LayoutConfiguration name="Default">
			<Size>
				<Width percentage="100" />
				<Height percentage="95" />
				<OriginalSize width="640" height="706" />
			</Size>
			<Translation>
				<X percentage="50" />
				<Y percentage="50" />
			</Translation>
		</LayoutConfiguration>
	</SceneObject>
</Scene>

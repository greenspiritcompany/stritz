		<Texture filename="shared/game/common/tex/candy/colorbomb_c.png"/>
		<Light shininess="16" enabled="true">
			<Specular a="255" r="100" g="100" b="100"/>
			<Ambient a="255" r="150" g="150" b="150"/>

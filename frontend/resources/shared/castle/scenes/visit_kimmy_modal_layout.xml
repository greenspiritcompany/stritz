<!DOCTYPE Layout SYSTEM '../../dtd/layout.dtd'>
<Layout>
	<Object sceneObject="Landscape">
		<Landscape visible="true"/>
		<Portrait visible="false"/>
	</Object>
	<Object sceneObject="Portrait">
		<Landscape visible="false"/>
		<Portrait visible="true"/>
	</Object>
	<Object sceneObject="VisitKimmyModal">
		<Default>
			<Translation>
				<X percentage="50"/>
				<Y percentage="50"/>
			</Translation>
			<Size>
				<Height percentage="100"/>
				<OriginalSize height="768" width="1024"/>
			</Size>
		</Default>
		<Portrait>
			<Translation>
				<X percentage="50"/>
				<Y percentage="50"/>
			</Translation>
			<Size>
				<OriginalSize height="1024" width="684"/>
				<Width percentage="100"/>
			</Size>
		</Portrait>
	</Object>
</Layout>

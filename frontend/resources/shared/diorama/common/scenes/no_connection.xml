		<Import filename="shared/diorama/common/scenes/modal_background_small.xml" />
		<SceneObject name="TitleText">
			<Translation x="0" y="-236" />
			<Text canBreakWords="false" font="Banana" alignment="center" verticalAlignment="visualCenter" maxWidth="410" maxHeight="40" overflowBehaviour="fit" key="no_connection_title">
				<Size x="26" y="26" />
			</Text>
		</SceneObject>
		<SceneObject>
			<Translation x="0" y="-60" />
			<Sprite filename="shared/diorama/common/tex/gui_elements/no_connection_icon.png" vertexColors="false">
				<Pivot anchor="center" />
			</Sprite>
		</SceneObject>
		<SceneObject name="MessageArea">
			<Translation x="0" y="128" />
			<SceneObject>
				<Panel filename="shared/diorama/common/tex/gui_elements/purchase_fail_box.png" vertexColors="false">

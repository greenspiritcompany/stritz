<?xml version="1.0" standalone="no"?>
<!DOCTYPE Scene SYSTEM "../../../../dtd/scene.dtd">
<Scene>
	<Materials>
		<!--
			EPISODEMATERIAL & EPISODEMATERIALALPHA
		-->
		<Material name="Episode14Material">
			<Cull enabled="false" face="back"/>
			<Textures>
				<Texture filename="shared/diorama/diorama05/episode14/tex/episode14_material.png"/>
			</Textures>
		</Material>

		<Material name="Episode14MaterialAlpha" parentMaterial="Episode14Material">
			<Depth writeMask="false" enabled="true"/>
			<Blend enabled="true"/>
		</Material>
    
		<!--
			PATHMATERIAL & PATHMATERIALALPHA
		-->
		<Material name="Episode14PathMaterial">
			<Cull enabled="true" face="back"/>

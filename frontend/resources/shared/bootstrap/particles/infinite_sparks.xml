<!DOCTYPE ParticleEffect SYSTEM '../../dtd/particle_effect.dtd'>
<ParticleEffect maxParticles="64" space="World" timeToEmit="60" name="InfiniteSparks">
    <Dampening max="0.900" min="0.900"/>
    <DirectionalForce x="0" y="200"/>
    <Emitter emissionRate="0.010" spread="360" angle="0">
        <SpawnArea width="30" depth="0" height="30"/>
    </Emitter>
    <EndColor b="100" r="100" g="100" a="0"/>
    <Rotation max="450" min="-100"/>
    <RotationSpeed max="800" min="400"/>
    <Size>
        <Max x="57" y="57"/>
        <Min x="8" y="8"/>
    </Size>
    <SizeChange>
        <Max x="-36" y="-36"/>
        <Min x="0" y="0"/>
    </SizeChange>
    <StartColor b="255" r="255" g="255" a="255"/>
    <Texture numFramesY="1" blend="Add" numFramesX="1" filename="shared/bootstrap/particles/tex/nice_spark.png"/>
    <TextureFrame numTextureAnimationFrames="1" textureAnimationSpeed="50" startFrame="0"/>
    <TimeToLive max="0.400" min="0.400"/>
    <Velocity max="-200" min="200"/>
</ParticleEffect>

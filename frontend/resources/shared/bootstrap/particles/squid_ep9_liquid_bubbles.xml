<!DOCTYPE ParticleEffect SYSTEM '../../dtd/particle_effect.dtd'>
<ParticleEffect maxParticles="6" space="Local" timeToEmit="0.500" name="SquidBubbles">
    <Dampening max="0.980" min="0.900"/>
    <DirectionalForce x="0" y="50"/>
    <Emitter emissionRate="0.100" spread="45" angle="90">
        <SpawnArea width="80" depth="0" height="10"/>
    </Emitter>
    <EndColor b="255" r="255" g="255" a="200"/>
    <Rotation max="90" min="20"/>
    <RotationSpeed max="90" min="90"/>
    <Size>
        <Max x="40" y="40"/>
        <Min x="25" y="25"/>
    </Size>
    <SizeChange>
        <Max x="-50" y="-50"/>
        <Min x="-35" y="-35"/>
    </SizeChange>
    <StartColor b="255" r="255" g="255" a="255"/>
    <Texture numFramesY="1" blend="Multiply" numFramesX="1" filename="shared/bootstrap/particles/tex/bubble.png"/>
    <TextureFrame numTextureAnimationFrames="1" textureAnimationSpeed="60" startFrame="0"/>
    <TimeToLive max="0.600" min="0.400"/>
    <Velocity max="280" min="180"/>
</ParticleEffect>

    <DirectionalForce x="100" y="-200"/>
    <Emitter emissionRate="0.300" spread="0" angle="0">
        <SpawnArea width="0" depth="0" height="0"/>
    </Emitter>
    <EndColor b="255" r="255" g="255" a="0"/>
    <Rotation max="100" min="-100"/>
    <RotationSpeed max="0" min="0"/>
    <Size>
        <Max x="30" y="30"/>
        <Min x="20" y="20"/>
    </Size>
    <SizeChange>
        <Max x="30" y="30"/>
        <Min x="10" y="10"/>
    </SizeChange>
    <StartColor b="255" r="255" g="255" a="255"/>
    <Texture numFramesY="1" blend="Multiply" numFramesX="1" filename="shared/bootstrap/particles/tex/cartoon_smoke64.png"/>
    <TextureFrame numTextureAnimationFrames="1" textureAnimationSpeed="60" startFrame="0"/>
    <TimeToLive max="2.500" min="1.200"/>
    <Velocity max="100" min="50"/>

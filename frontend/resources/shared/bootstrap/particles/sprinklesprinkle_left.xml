    <StartColor b="255" r="255" g="255" a="255"/>
    <Texture numFramesY="1" blend="Multiply" numFramesX="1" filename="shared/bootstrap/particles/tex/sprinklesprinkle_blue.png"/>
    <TextureFrame numTextureAnimationFrames="1" textureAnimationSpeed="60" startFrame="0"/>

<!DOCTYPE Timelines SYSTEM "../../../dtd/timeline.dtd">
<Timelines>
	<Timeline startTime="0.0" endTime="0.75">

		<Animate target="CheckmarkLandscape" time="0.0">
			<Hide time="0.0"/>
			<Show time="0.01"/>
		</Animate>
		<Animate target="CheckmarkPortrait" time="0.0">
			<Hide time="0.0"/>
			<Show time="0.01"/>
		</Animate>
		<Triggers>
			<AnimationTrigger animationName="Show" targetName="Checkmark" time="0.0"/>
			<EffectTrigger time="0.5" name="ReachGoalSpark" parentName="CheckmarkLandscapeRoot"
						   targetName="CheckmarkLandscape"/>
			<EffectTrigger time="0.5" name="ReachGoalSpark" parentName="CheckmarkPortraitRoot"
						   targetName="CheckmarkPortrait"/>
			<AnimationTrigger animationName="Show" targetName="CheckmarkPortrait" time="0.0"/>
		</Triggers>

	</Timeline>
</Timelines>
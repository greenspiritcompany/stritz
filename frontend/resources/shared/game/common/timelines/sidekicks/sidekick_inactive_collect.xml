<!DOCTYPE Timelines SYSTEM "../../../../../../tools/timeline.dtd">
<Timelines>
	<Timeline startTime="0.0" endTime="2.7">

		<!-- Active and Inactive refers to the sidekick -->
		<Animate target="Active" time="0.0">
			<Hide/>
		</Animate>

        <Animate target="ThoughtBubble" time="0.0">
            <Hide/>
        </Animate>

		<Animate target="Inactive" time="0.0">
			<Show/>
		</Animate>

		<Triggers>
			 <AnimationTrigger time="0.7" targetName="Inactive" animationName="cyan_collect"/>

			 <CustomTrigger name="collectDone" time="2.5"/>
			 <CustomTrigger name="collectDoneIfCharged" time="1.0"/>

			<EffectTrigger name="ProgressTrailEFQ" targetName="ProgressModel" targetBoneIndex="14" followTarget="true" time="0.5"/>

			<EffectTrigger name="SidekickCyanSelectedEFQ" targetName="Inactive" targetBoneIndex="3" time="0.6">
                <Offset z="100"/>
			</EffectTrigger>

            <EffectTrigger name="SidekickCollectSFX" time="0.3"/>
            <EffectTrigger name="SidekickChargeSFX" time="0.65"/>
		</Triggers>
	</Timeline>
</Timelines>
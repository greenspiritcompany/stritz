        <!--
			EPISODEMATERIAL & EPISODEMATERIALALPHA
		-->
        <Material name="Episode32Material">
            <Cull enabled="false" face="back"/>
            <Textures>
                <Texture filename="shared/diorama/diorama11/episode32/tex/episode32_material.png"/>
            </Textures>
        </Material>
        <Material name="Episode32MaterialAlpha" parentMaterial="Episode32Material">
            <Depth enabled="true" writeMask="false"/>
            <Blend enabled="true"/>
        </Material>
        <!--
			PATHMATERIAL & PATHMATERIALALPHA
		-->
        <Material name="Episode32PathMaterial">
            <Cull enabled="true" face="back"/>
            <Textures>
                <Texture
                    filename="shared/diorama/common/tex/path_tex.png" wrap="repeat"/>
            </Textures>
        </Material>
        <Material name="Episode32PathMaterialAlpha" parentMaterial="Episode32PathMaterial">
            <Depth enabled="true" writeMask="false"/>
            <Blend enabled="true"/>
        </Material>
        <!--
			BACKDROPMATERIAL & BACKDROPMATERIALALPHA
		-->
        <Material name="Episode32BackdropMaterial">
            <Cull enabled="true" face="back"/>
            <Textures>
                <Texture
                    filename="shared/diorama/diorama11/episode32/tex/episode32_material.png" wrap="repeat"/>
            </Textures>
        </Material>
        <Material name="Episode32BackdropMaterialAlpha" parentMaterial="Episode32BackdropMaterial">
            <Depth enabled="true" writeMask="false"/>
            <Blend enabled="true"/>
        </Material>
    </Materials>

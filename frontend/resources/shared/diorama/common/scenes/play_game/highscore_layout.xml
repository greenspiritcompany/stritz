<?xml version="1.0" standalone="no"?>
<!DOCTYPE Layout SYSTEM "../../../../dtd/layout.dtd">
<Layout>
	<Object sceneObject="HighscoresList">
		<Default>
			<Translation>
				<X percentage="50.0"/>
				<Y percentage="50.0"/>
			</Translation>
			<Size>
				<Height percentage="100.0"/>
				<OriginalSize height="768" width="1024"/>
			</Size>
		</Default>
		<Portrait>
			<Translation>
				<X percentage="50.0"/>
				<Y percentage="50.0"/>
			</Translation>
			<Size>
				<Width percentage="100.0"/>
				<OriginalSize height="1024" width="684"/>
			</Size>
		</Portrait>
	</Object>
	<Object sceneObject="HighscoresLandscape">
		<Landscape visible="true"/>
		<Portrait visible="false"/>
	</Object>
	<Object sceneObject="HighscoresPortrait">
		<Landscape visible="false"/>
		<Portrait visible="true"/>
	</Object>
</Layout>
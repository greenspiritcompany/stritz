			</Textures>
		</Material>
		<Material name="Episode14PathMaterialAlpha" parentMaterial="Episode14PathMaterial">
			<Depth writeMask="false" enabled="true"/>
			<Blend enabled="true"/>
		</Material>
    
		<!--
			BACKDROPMATERIAL & BACKDROPMATERIALALPHA
		-->
		<Material name="Episode14BackdropMaterial">
			<Cull enabled="true" face="back"/>
			<Textures>
				<Texture filename="shared/diorama/diorama05/episode14/tex/episode14_material.png" wrap="repeat"/>
			</Textures>
		</Material>
		<Material name="Episode14BackdropMaterialAlpha" parentMaterial="Episode14BackdropMaterial">
			<Depth writeMask="false" enabled="true"/>
			<Blend enabled="true"/>
		</Material>
	</Materials>
  

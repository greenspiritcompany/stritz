<?xml version="1.0" standalone="no"?>
<!DOCTYPE Scene SYSTEM "../../../dtd/scene.dtd">

<Scene>
	<Materials>
		<Material name="FizzMaterial">
            <Blend enabled="true"/>
            <Depth enabled="true" writeMask="false"/>
            <Cull enabled="false" face="back"/>
			<!-- Set to false since the vertex winding seems messed up between FF and SL -->
			<Shader program="NormalMap"/>
			<Light enabled="true" shininess="80">
				<Ambient r="255" g="170" b="255" a="255"/>
				<Diffuse r="180" g="180" b="180" a="255"/>
				<Specular r="255" g="255" b="255" a="255"/>
			</Light>
		</Material>

		<Material name="FizzMaterialBlue" parentMaterial="FizzMaterial">
			<Textures>

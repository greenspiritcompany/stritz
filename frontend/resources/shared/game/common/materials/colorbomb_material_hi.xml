<!DOCTYPE Scene SYSTEM '../../../dtd/scene.dtd'>
<Scene>
	<Material name="ColorBombMaterial">
		<Blend enabled="false"/>
		<Cull enabled="true"/>
		<Depth enabled="true" writeMask="true"/>
		<Shader program="NormalMapInvertY"/>
		<Light enabled="true" shininess="15">
			<Ambient r="150" g="150" b="150" a="255"/>
			<Diffuse r="155" g="155" b="155" a="255"/>
			<Specular r="100" g="100" b="100" a="255"/>
		</Light>
		<Texture filename="shared/game/common/tex/candy/colorbomb_c.png"/>
		<Texture filename="shared/game/common/tex/candy/colorbomb_n.png"/>
	</Material>
	<Material name="ColorBombShadowMaterial">
		<Color r="255" g="255" b="255" a="255"/>
		<Blend enabled="true"/>
		<Depth enabled="true" writeMask="false"/>
		<Shader program="TextureColor"/>
		<Texture filename="shared/game/common/tex/candy/colorbomb_c.png"/>
		<Cull enabled="true"/>
	</Material>
</Scene>

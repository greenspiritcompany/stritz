<?xml version="1.0" standalone="no"?>
<!DOCTYPE Scene SYSTEM "../../../dtd/scene.dtd">

<Scene>
	<Materials>
		<Material name="CupcakeMaterial">
			<Blend enabled="true"/>
			<Depth enabled="false" writeMask="false"/>
			<Cull enabled="false" face="back"/>
			<!-- Set to false since the vertex winding seems messed up between FF and SL -->
			<Shader program="NormalMap"/>
			<Light enabled="true" shininess="60">
				<Ambient r="230" g="230" b="230" a="255"/>
				<Diffuse r="40" g="40" b="40" a="255"/>
				<Specular r="90" g="90" b="90" a="255"/>
			</Light>
		</Material>
	</Materials>
</Scene>
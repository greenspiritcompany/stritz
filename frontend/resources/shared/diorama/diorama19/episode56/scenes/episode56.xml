	<!--
			EPISODEMATERIAL & EPISODEMATERIALALPHA
		-->
	<Material name="Episode56Material">
		<Cull enabled="false" face="back" />
		<Texture filename="shared/diorama/diorama19/episode56/tex/episode56_material.png" />
	</Material>
	<Material name="Episode56MaterialAlpha" parentMaterial="Episode56Material">

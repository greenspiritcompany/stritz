			<Hide time="0.0"/>
			<Show time="0.0"/>
		</Animate>
		<Triggers>
			<EffectTrigger name="SwipeSwoopInEFQ" time="0.0"/>
			<EffectTrigger name="SwipeSwoopOutEFQ" time="0.51"/>

			<CustomTrigger time="1.05" data="SwipeEnd" name="SwipeEnd"/>

			<AnimationTrigger targetName="AnimateBg" animationName="SlideToRight" time="0.0"/>

			<AnimationTrigger targetName="Scene" animationName="OnLoseAppear" time="0.0"/>

<!DOCTYPE Scene SYSTEM '../../dtd/scene.dtd'>
<Scene>
    <SceneObject name="Avatar">
        <SceneObject name="Frame">
            <Sprite vertexColors="false" filename="shared/diorama/common/tex/gui_elements/photo_frame_pink.png">
                <Pivot anchor="center"/>
                <Scale y="0.90" x="0.90"/>
            </Sprite>
        </SceneObject>
        <SceneObject name="Spinner">
            <Translation y="-1" z="1"/>
            <Animation animationData="Rotate360" loopCount="-1" name="rotate" play="true"/>
            <Sprite filename="shared/preloader/tex/spinner.png">
                <Pivot anchor="center"/>
                <Size width="50" height="50"/>
            </Sprite>
        </SceneObject>
        <SceneObject name="Profile">
            <Translation y="-1" z="-1"/>
            <Sprite filename="shared/diorama/common/tex/gui_elements/prof_pic.png">
                <Pivot anchor="center"/>
            </Sprite>
        </SceneObject>
        <SceneObject name="Name">
            <Translation y="43.50" x="0"/>
            <Text maxWidth="80" alignment="center" overflowBehaviour="fit" verticalAlignment="visualCenter" font="TypewriterBold" maxHeight="20">
                <Color b="128" g="62" r="165" a="255"/>
                <Size y="12" x="12"/>
            </Text>
        </SceneObject>
    </SceneObject>
</Scene>

                <Ambient r="173" g="183" b="180" a="255"/>
                <Diffuse r="145" g="145" b="145" a="255"/>
                <Specular r="102" g="102" b="102" a="255"/>
            </Light>
                <Textures>
                    <Texture filename="shared/game/common/tex/candy/liquorice_swirl_c.png"/>
                    <Texture filename="shared/game/common/tex/candy/liquorice_swirl_n.png"/>
                </Textures>
        </Material>
    </Materials>
